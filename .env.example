# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000                          # Web server port (default 3000)

# ─── Airtable ─────────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=pat...            # airtable.com/create/tokens → data.records:write
AIRTABLE_BASE_ID=app...            # from your base URL: airtable.com/app.../
AIRTABLE_TABLE_NAME=Contacts       # exact table name

# ─── Gmail ────────────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Enable Gmail API
# Credentials → OAuth 2.0 Client ID → Desktop app
# Authorized redirect URIs → add: http://localhost:3000/oauth/callback
GMAIL_CLIENT_ID=....apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REDIRECT_URI=http://localhost:3000/oauth/callback

# ─── LinkedIn ─────────────────────────────────────────────────────────────────
# Get cookie: Chrome → linkedin.com → DevTools (F12) → Application tab →
# Cookies → linkedin.com → li_at → copy Value
# Expires every ~2 weeks — re-copy when enrichment fails
LINKEDIN_SESSION_COOKIE=AQE...
LINKEDIN_BATCH_LIMIT=40
LINKEDIN_DELAY_MS=3500

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_EXPORTS_DIR=./whatsapp-exports

# ─── Twitter / X (optional) ───────────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
